# Copy this to .env and fill in values you want to enable

DATABASE_URL=postgresql://pulsecoach:pulsecoach@db:5432/pulsecoach

# Optional: verify Health Auto Export webhook calls
WEBHOOK_SECRET=

# Hevy integration (requires Hevy Pro subscription)
ENABLE_HEVY=false
HEVY_API_KEY=

# AI coaching (requires Anthropic API key)
ENABLE_COACHING=false
ANTHROPIC_API_KEY=
# Verify the current model name at https://docs.anthropic.com/en/docs/models-overview
# Do NOT hardcode a model name here — it changes frequently.
CLAUDE_MODEL=
