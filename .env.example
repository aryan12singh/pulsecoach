# Copy this to .env and fill in values you want to enable.
# This is the ONLY file you need to edit — it is read by Docker Compose for both
# the backend container and the frontend build args.

DATABASE_URL=postgresql://pulsecoach:pulsecoach@db:5432/pulsecoach

# URL the browser uses to reach the backend (inlined into the Next.js build)
NEXT_PUBLIC_API_URL=http://localhost:8010

# Optional: encrypt secrets stored in the settings DB table
SETTINGS_ENCRYPTION_KEY=

# Optional: verify Health Auto Export webhook calls
WEBHOOK_SECRET=

# Hevy integration (requires Hevy Pro subscription)
# Supports both on-demand pull (/ingest/hevy/sync) and a webhook (/ingest/hevy/webhook)
ENABLE_HEVY=false
HEVY_API_KEY=

# Strava integration (v2) — register an app at https://www.strava.com/settings/api
ENABLE_STRAVA=false
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match the callback registered in your Strava app settings
STRAVA_REDIRECT_URI=http://localhost:8010/ingest/strava/callback
FRONTEND_URL=http://localhost:3010

# AI coaching (requires Anthropic API key)
ENABLE_COACHING=false
ANTHROPIC_API_KEY=
# Verify the current model name at https://docs.anthropic.com/en/docs/models-overview
# Do NOT hardcode a model name here — it changes frequently.
CLAUDE_MODEL=
