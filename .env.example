# Copy this to .env and fill in values you want to enable.
# This is the ONLY file you need to edit — Docker Compose reads it for both
# the backend container and the frontend build args.
#
# NOTE: env values only SEED the settings database on first boot. After that,
# manage everything from the in-app Settings page — restarts never overwrite
# what you changed in the UI.

DATABASE_URL=postgresql://pulsecoach:pulsecoach@db:5432/pulsecoach

# Load demo data (fake workouts/metrics) into an EMPTY database. Leave false
# to start clean and import your own history.
SEED_DEMO=false

# Backend log verbosity: DEBUG | INFO | WARNING
LOG_LEVEL=INFO

# How the browser reaches the API. Leave EMPTY (recommended) to use the
# frontend's same-origin /api proxy — this is what makes phone/LAN/hosted
# access work without rebuilding. Set to http://localhost:8010 to bypass it.
NEXT_PUBLIC_API_URL=

# Where the /api proxy forwards to (compose-internal address).
BACKEND_URL=http://backend:8000

# Optional: verify Health Auto Export webhook calls
WEBHOOK_SECRET=

# Hevy integration (requires Hevy Pro subscription for the live API;
# CSV import in Settings works without Pro)
ENABLE_HEVY=false
HEVY_API_KEY=

# Strava integration — register an app at https://www.strava.com/settings/api
ENABLE_STRAVA=false
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match the callback registered in your Strava app settings
STRAVA_REDIRECT_URI=http://localhost:8010/ingest/strava/callback
FRONTEND_URL=http://localhost:3010

# AI coaching (requires an Anthropic API key)
ENABLE_COACHING=false
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-opus-4-8 when left blank
CLAUDE_MODEL=
